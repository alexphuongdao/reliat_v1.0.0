# Reliat web — environment template.
# Copy to `.env.local` for local dev, set the same vars in Vercel for prod.

# URL where services/api (FastAPI) is reachable.
#   Local dev:    http://localhost:8000
#   Vercel prod:  https://<your-app>.up.railway.app   (or your custom domain)
#
# Must be NEXT_PUBLIC_* because the client fetches directly from the browser.
NEXT_PUBLIC_API_BASE=http://localhost:8000
